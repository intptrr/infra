# NOTE: root and non-root users MUST have different usernames AND different passwords.
# Generate strong unique passwords, e.g.: openssl rand -base64 24

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-root

POSTGRES_DB=n8n

POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=changeme-n8n

# Used to encrypt stored credentials. MUST be set and kept stable across restarts.
# Losing this value makes all stored credentials unrecoverable.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-hex-32

# Timezone. Used for both n8n schedule/cron logic (GENERIC_TIMEZONE)
# and the container system clock (TZ).
TZ=America/Los_Angeles

# Public URL will be https://${SUBDOMAIN}.${DOMAIN_NAME}/
DOMAIN_NAME=example.com
SUBDOMAIN=n8n

